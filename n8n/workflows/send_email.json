    {
      "parameters": {
        "jsCode": "const emailResult = $json;\nconst messageId = emailResult.id || emailResult.messageId || emailResult.threadId;\n\nif (!messageId) {\n  throw new Error('Gmail did not return a messageId - email may not have been sent');\n}\n\nreturn {\n  success: true,\n  messageId,\n  deliveryMetadata: {\n    provider: 'GMAIL',\n    sentAt: new Date().toISOString(),\n    status: 'sent'\n  }\n};"
      },
      "id": "e0a0d0a3-4321-4b11-a889-333333333333",
      "name": "Build Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1260, 300]
    },
    {
      "parameters": {
        "jsCode": "const errorData = $json;\nconst errorMsg = errorData.message || errorData.error || JSON.stringify(errorData);\n\nreturn {\n  success: false,\n  error: errorMsg,\n  rawError: errorData\n};"
      },
      "id": "e0a0d0a3-4321-4b11-a889-666666666666",
