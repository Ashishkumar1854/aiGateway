{
  "id": "LLPQmXL6UVr0x8hv",
  "name": "Smart Apply - Send Email",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "send-email",
        "responseMode": "responseNode",
        "responseData": "allEntries",
        "options": {}
      },
      "id": "e0a0d0a3-4321-4b11-a889-111111111111",
      "name": "webhook-trigger",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [0, 300]
    },
    {
      "parameters": {
        "jsCode": "// === Resolve PDF URL from input ===\nconst body = $json.body || $json;\nlet pdfLocation = body.pdfLocation || '';\nlet hasAttachment = false;\nconst fileName = body.fileName || 'Resume.pdf';\n\nif (pdfLocation) {\n  if (pdfLocation.includes('drive.google.com')) {\n    let fileId = '';\n    const fileDMatch = pdfLocation.match(/\\/file\\/d\\/([a-zA-Z0-9_-]+)/);\n    if (fileDMatch && fileDMatch[1]) {\n      fileId = fileDMatch[1];\n    } else {\n      const idParamMatch = pdfLocation.match(/[?&]id=([a-zA-Z0-9_-]+)/);\n      if (idParamMatch && idParamMatch[1]) {\n        fileId = idParamMatch[1];\n      }\n    }\n    if (fileId) {\n      pdfLocation = `https://drive.google.com/uc?export=download&id=${fileId}`;\n    }\n  }\n  hasAttachment = true;\n}\n\nreturn {\n  hasAttachment,\n  pdfLocation,\n  fileName,\n  hrEmail: body.hrEmail,\n  subject: body.subject,\n  emailBody: body.body\n};"
      },
      "id": "e0a0d0a3-4321-4b11-a889-888888888888",
      "name": "Resolve URL",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [200, 300]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ $json.hasAttachment }}",
              "value2": true
            }
          ]
        }
      },
      "id": "e0a0d0a3-4321-4b11-a889-ifcheck11111",
      "name": "Has Attachment?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [400, 300]
    },
    {
      "parameters": {
        "url": "={{ $json.pdfLocation }}",
        "responseFormat": "file",
        "options": {}
      },
      "id": "e0a0d0a3-4321-4b11-a889-aaaaaaaaaaaa",
      "name": "Download PDF",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [620, 160]
    },
    {
      "parameters": {
        "jsCode": "// Rename the binary attachment and pass through email data\nconst resolveData = $('Resolve URL').item.json;\nconst fileName = resolveData.fileName || 'Resume.pdf';\n\nconst item = {\n  json: {\n    hrEmail: resolveData.hrEmail,\n    subject: resolveData.subject,\n    emailBody: resolveData.emailBody\n  }\n};\n\n// Rename binary key to 'attachment'\nif ($binary && $binary.data) {\n  item.binary = {\n    attachment: {\n      ...$binary.data,\n      fileName: fileName,\n      mimeType: 'application/pdf'\n    }\n  };\n}\n\nreturn item;"
      },
      "id": "e0a0d0a3-4321-4b11-a889-bbbbbbbbbbbb",
      "name": "Prepare Attachment",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [820, 160]
    },
    {
      "parameters": {
        "authentication": "oAuth2",
        "resource": "message",
        "operation": "send",
        "sendTo": "={{ $json.hrEmail }}",
        "subject": "={{ $json.subject }}",
        "emailType": "html",
        "message": "={{ $json.emailBody }}",
        "options": {
          "attachmentsUi": {
            "attachmentsBinary": [
              {
                "property": "attachment"
              }
            ]
          }
        }
      },
      "id": "e0a0d0a3-4321-4b11-a889-222222222222",
      "name": "Send With Attachment",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.1,
      "position": [1040, 160],
      "credentials": {
        "gmailOAuth2": {
          "id": "OjeHG0aqekQOf1k1",
          "name": "Gmail account"
        }
      },
      "onError": "continueErrorOutput"
    },
    {
