{
  "name": "aigw-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "AiGateway — AI-powered IT company SaaS platform",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "start": "./aigw.sh start",
    "stop": "./aigw.sh stop",
    "restart": "./aigw.sh restart",
    "status": "./aigw.sh status",
    "logs": "./aigw.sh logs",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{js,jsx,json,md,css}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "test": "turbo run test"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "prettier": "^3.2.5",
    "eslint": "^8.57.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.1.0"
}
