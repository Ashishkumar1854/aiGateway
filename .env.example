# ════════════════════════════════════════════════════════════════
# AiGateway — Environment Variables Reference
# Copy this file to .env and fill in your values
# NEVER commit .env to Git
# ════════════════════════════════════════════════════════════════

# ─── App ────────────────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:5000
LOG_LEVEL=debug

# ─── Database (PostgreSQL) ──────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/aigw
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=aigw

# ─── Redis ──────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── n8n (internal Docker only) ─────────────────────────────────
N8N_URL=http://n8n:5678
N8N_WEBHOOK_SECRET=your-n8n-webhook-secret
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=password

# ─── AI Workers (internal Docker only) ──────────────────────────
AI_WORKERS_URL=http://ai-workers:8000
AI_WORKERS_SECRET=your-ai-workers-secret

# ─── Anthropic Claude ───────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── Billing (Razorpay) ─────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# ─── Email (SendGrid) ───────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=hello@yourcompany.com
FROM_NAME=AiGateway

# ─── Frontend URLs ──────────────────────────────────────────────
PUBLIC_WEB_URL=http://localhost:3000
CLIENT_DASHBOARD_URL=http://localhost:3001
ADMIN_DASHBOARD_URL=http://localhost:3002
NEXT_PUBLIC_API_URL=http://localhost:5000

# ─── CORS ───────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# ─── Rate Limiting ──────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
